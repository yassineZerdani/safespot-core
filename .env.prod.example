# Production environment for OVH deployment
# Copy to .env and fill in values before: docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# Required
POSTGRES_PASSWORD=your-secure-db-password
DJANGO_SECRET_KEY=your-long-random-secret-key
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,123.45.67.89
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional (defaults shown)
POSTGRES_USER=safespot
POSTGRES_DB=safespot
